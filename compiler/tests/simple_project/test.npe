project 'Test_Project';

{$program-type Windows32 GUI}

//import
//  FileIO;

type
  TFileOpenModeEnum = (fomNormal, fomRead, fomWrite, fomReadWrite);
  TBytes = Array of Byte;

  FileIO = class
  public
    OpenFile(const FileName: String, const FileOpenMode: Byte): (ok: Boolean, FileHandle: Integer);
    CloseFile(const FileHandle: Integer): Boolean;
    ReadAllBytes(const FileHandle: Integer): (ok: Boolean, Bytes: Array of Byte);
  end;

var
  ConsoleAvailable: Boolean = True;

// class FileIO method definitions

FileIO.OpenFile(const FileName: String, const FileOpenMode: Byte): (ok: Boolean, FileHandle: Integer) {
// to be filled later
};

FileIO.CloseFile(const FileHandle: Integer): Boolean {
// to be filled later
};

FileIO.ReadAllBytes(const FileHandle: Integer): (ok: Boolean, Bytes: Array of Byte) {
// to be filled later
};

Writeln(const Value: String) {
// empty procedure
};

ReadAllBytes(const FileName: String, const Mode: TFileOpenModeEnum): (ok: Boolean, output: TBytes) {
  ok, file := FileIO.OpenFile(FileName, Mode);
  if !ok then
    Return .{ok, null}; // just like in C, exits from function with some assigned return variables
  defer FileIO.CloseFile(file); // close file at function exit

  ok, bytes := FileIO.ReadAllBytes(file);

  Result .{ok, bytes}; // just like in Pascal, only stores values in assigned return variables
};

begin
  // program initialization code
  SomeString := 'this is a text';
  if ConsoleAvailable then {
    Writeln(SomeString);
//    ConsolePause;
  };
end.
