ReadAllBytes(const FileName: String, const Mode: TFileOpenModeEnum): (ok: Boolean, output: TBytes) {
  ok, file := FileIO.OpenFile(FileName, Mode);
  if !ok then
    Return .{ok, null};
  defer FileIO.CloseFile(File);

  ok, bytes := FileIO.ReadAllBytes(File);

  Result .{ok, bytes};
};

